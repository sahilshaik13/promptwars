# SmartVenue AI - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# ==========================================
# FRONTEND (Vite)
# ==========================================

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Maps API Key (optional if using backend maps proxy)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# GCloud Bucket URL (for signed image URLs)
VITE_GCLOUD_BUCKET_URL=https://storage.googleapis.com/your-bucket

# ==========================================
# BACKEND (FastAPI)
# ==========================================

# Supabase Service Role Key (backend only - NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Secret for token verification
SUPABASE_JWT_SECRET=your-jwt-secret

# Gemini API Key (for AI features)
GEMINI_API_KEY=your-gemini-api-key

# Google Maps API Key (backend proxy)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# GCloud Storage (for signed URLs)
GCS_BUCKET_NAME=your-gcs-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ==========================================
# SECURITY NOTES
# ==========================================
# 1. All secrets should be stored in environment variables, not in code
# 2. The .env file is gitignored - never commit actual values
# 3. In production, use secret management (GCP Secret Manager, AWS Secrets Manager, etc.)
# 4. Rotate API keys periodically
# 5. Use different keys for development and production
